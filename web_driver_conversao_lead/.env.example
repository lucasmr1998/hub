# Renomeie para `.env.hubtrix` (gitignored) e preencha com valores reais.

# DB Hubtrix (prod) — onde a tabela `prospectos` mora.
HUBTRIX_DB_HOST=
HUBTRIX_DB_PORT=5433
HUBTRIX_DB_NAME=hub
HUBTRIX_DB_USER=
HUBTRIX_DB_PASSWORD=

# Mesma SECRET_KEY do Django prod (precisa pra decryptar IntegracaoAPI.password).
SECRET_KEY=

# Slug do tenant default quando --tenant nao for passado.
DEFAULT_TENANT_SLUG=nuvyon

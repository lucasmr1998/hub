# ============================================================================
# AuroraISP — Variáveis de ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env no repositório.
# ============================================================================

# Django
SECRET_KEY=gere-uma-nova-chave-com-django-get-random-secret-key
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# Banco de dados (PostgreSQL)
DB_NAME=robovendas
DB_USER=admin
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Matrix API (WhatsApp)
MATRIX_API_URL=https://megalink.matrixdobrasil.ai/rest/v1/atendimento
MATRIX_API_TOKEN=

# HubSoft (usado pelo command setup_hubsoft)
HUBSOFT_BASE_URL=
HUBSOFT_CLIENT_ID=
HUBSOFT_CLIENT_SECRET=
HUBSOFT_USERNAME=
HUBSOFT_PASSWORD=

# HubSoft Database (leitura direta, usado pelo módulo CS)
HUBSOFT_DB_USER=
HUBSOFT_DB_PASSWORD=
HUBSOFT_DB_HOST=
HUBSOFT_DB_PORT=9432
HUBSOFT_DB_NAME=hubsoft

# Segurança — Tokens de autenticação para webhooks e APIs externas
WEBHOOK_SECRET_TOKEN=gere-um-token-aleatorio-longo
N8N_API_TOKEN=gere-outro-token-aleatorio-longo

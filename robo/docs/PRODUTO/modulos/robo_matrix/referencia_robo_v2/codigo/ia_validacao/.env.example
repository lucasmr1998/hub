# OpenAI
OPENAI_API_KEY=sk-COLOQUE-AQUI
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT=20

# Servidor
HOST=0.0.0.0
PORT=8090
LOG_LEVEL=INFO

# Persona
PERSONA_NOME=Aurora
PERSONA_EMPRESA=Megalink

# Cache (opcional)
REDIS_URL=redis://localhost:6379/0
USAR_CACHE=false

# Integração com Robo Vendas (opcional)
ROBOVENDAS_API_URL=https://robovendas.megalinkpiaui.com.br

# ── Camada conversacional (rota /conv, opt-in) ──────────────
# Modelo melhor pra conversação (gpt-4o recomendado). Fallback: gpt-4o-mini
OPENAI_MODEL_CONVERSA=gpt-4o
OPENAI_CONV_TIMEOUT=30
# Liga/desliga cada passo independente
CONV_PASSO1_HUMANIZAR=true
CONV_PASSO2_EXTRACAO=true
CONV_PASSO3_FAQ=true
